{
  "name": "@better-auth-ui/solid",
  "version": "1.6.27",
  "type": "module",
  "scripts": {
    "build": "vite build && vite build --config vite.email.config.ts",
    "dev": "tsc --watch",
    "test": "vitest"
  },
  "files": [
    "src",
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./email": {
      "types": "./dist/email.d.ts",
      "import": "./dist/email.js"
    },
    "./plugins": {
      "types": "./dist/plugins.d.ts",
      "import": "./dist/plugins.js"
    }
  },
  "devDependencies": {
    "@better-auth/api-key": "^1.6.19",
    "@better-auth/passkey": "^1.6.19",
    "@solidjs-email/main": "^2.0.0",
    "@tanstack/solid-query": "^5.100.9",
    "@types/node": "^25.9.4",
    "better-auth": "^1.6.19",
    "solid-js": "^1.9.12",
    "vite-plugin-solid": "^2.11.8",
    "vitest": "^4.1.9",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@better-auth-ui/core": "*",
    "@better-auth/api-key": ">=1.6.19",
    "@better-auth/passkey": ">=1.6.19",
    "@solidjs-email/main": ">=2.0.0",
    "@tanstack/solid-query": ">=5.100.9",
    "better-auth": ">=1.6.19",
    "solid-js": ">=1.9.12",
    "zod": ">=4.4.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/better-auth-ui/better-auth-ui",
    "directory": "packages/solid"
  },
  "publishConfig": {
    "access": "public"
  }
}
